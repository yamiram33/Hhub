-- Script Local (StarterPlayerScripts)
-- Crea un panel con opciones de movimiento

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")

-- Crear ScreenGui
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")

-- Crear Frame
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 200, 0, 250)
frame.Position = UDim2.new(0, 20, 0, 100)
frame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
frame.Parent = screenGui

-- Función para crear botones
local function crearBoton(nombre, posicionY, callback)
    local boton = Instance.new("TextButton")
    boton.Size = UDim2.new(0, 180, 0, 30)
    boton.Position = UDim2.new(0, 10, 0, posicionY)
    boton.Text = nombre
    boton.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    boton.TextColor3 = Color3.fromRGB(255, 255, 255)
    boton.Parent = frame
    boton.MouseButton1Click:Connect(callback)
end

-- Opciones
crearBoton("Correr Rápido", 10, function()
    humanoid.WalkSpeed = 50 -- valor ajustable
end)

crearBoton("Saltar Alto", 50, function()
    humanoid.JumpPower = 100 -- valor ajustable
end)

crearBoton("Volar", 90, function()
    local fly = Instance.new("BodyVelocity")
    fly.Velocity = Vector3.new(0,50,0)
    fly.MaxForce = Vector3.new(0, math.huge, 0)
    fly.Parent = character:WaitForChild("HumanoidRootPart")
    wait(3)
    fly:Destroy()
end)

crearBoton("Invisible", 130, function()
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 1
        end
    end
end)

crearBoton("Reset Valores", 170, function()
    humanoid.WalkSpeed = 16 -- valor por defecto
    humanoid.JumpPower = 50 -- valor por defecto
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 0
        end
    end
end)
