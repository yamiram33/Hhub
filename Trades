local ReplicatedStorage = game:GetService("ReplicatedStorage")

local TradeConfirm = ReplicatedStorage:WaitForChild("TradeConfirm")

local activeTrades = {}

TradeConfirm.OnServerEvent:Connect(function(player, tradeId)
    local trade = activeTrades[tradeId]
    if not trade then return end

    trade.confirmations[player.UserId] = true

    -- Si ambos confirmaron
    if trade.confirmations[trade.player1.UserId] and 
       trade.confirmations[trade.player2.UserId] then
        
        -- Ejecutar intercambio seguro
        print("Trade completado")
        
        -- Aquí intercambias los brainrots correctamente
    end
end)
